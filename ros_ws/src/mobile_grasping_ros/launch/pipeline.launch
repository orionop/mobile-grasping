<?xml version="1.0"?>
<!--
  pipeline.launch
  ===============

  Brings up the three Python nodes that make up the closed-loop
  controller pipeline:

    - predictor_node    publishes /grasp_pose (fixed pose for bring-up)
    - estimator_node    republishes /odom as /base_pose
    - controller_node   solves the QP and publishes /arm_velocity_cmd

  This launch file is intentionally simulator-agnostic: it brings up
  only our nodes and assumes that /odom and /joint_states are already
  being published by something else (Gazebo, real hardware, or a bag).
  Compose it with sim.launch for a full simulation bring-up.
-->
<launch>

  <arg name="control_rate_hz" default="200.0"/>
  <arg name="predictor_rate_hz" default="30.0"/>
  <arg name="estimator_rate_hz" default="50.0"/>

  <!-- M1: base stationary (J_base = 0). M2: set true for base-motion compensation. -->
  <arg name="use_base_jacobian" default="false"/>

  <!-- Closed-loop (true) vs open-loop baseline (false: arm runs blind on the
       base pose latched at t=0). Exp 1 compares these. -->
  <arg name="feedback_enabled" default="true"/>

  <!-- Arm command interface (default "position"):
       "position"   -> integrate q_dot to a position setpoint, stream to a
                       JointGroupPositionController (MoveIt-Servo pattern; holds
                       against gravity AND tracks a moving setpoint). DEFAULT.
       "velocity"   -> q_dot straight to a JointGroupVelocityController (needs
                       the VelocityJointInterface transmission; sags in Gazebo).
       "trajectory" -> one-point JointTrajectory to the stock
                       JointTrajectoryController (laggy on moving setpoints). -->
  <arg name="cmd_interface" default="position"/>
  <arg name="arm_cmd_topic" default="/arm_pos_controller/command"/>
  <arg name="spawn_position_controller" default="true"/>
  <arg name="spawn_velocity_controller" default="false"/>

  <!-- Tracking-error logging for Exp 1 figure. Set eval:=true to record. -->
  <arg name="eval" default="false"/>
  <arg name="eval_csv" default="/tmp/tracking_error.csv"/>

  <!-- Fixed grasp target (world frame). Default kept inside the OMX-X
       reach (~0.38 m from arm base); 0.5 m was unreachable and saturated
       the QP. Override with target_x:=... etc. -->
  <arg name="target_x" default="0.25"/>
  <arg name="target_y" default="0.0"/>
  <arg name="target_z" default="0.20"/>

  <!-- Optional moving target (diagnostic: isolate arm velocity tracking). -->
  <arg name="target_vx" default="0.0"/>
  <arg name="target_vy" default="0.0"/>
  <arg name="target_vz" default="0.0"/>

  <!-- Position group controller (default reactive-servo interface). Replaces
       the stock arm_controller; uses the same PositionJointInterface. The
       bring-up launch must NOT also spawn the stock arm_controller (they claim
       the same joints) -- see sim_position.launch. -->
  <group if="$(arg spawn_position_controller)">
    <rosparam command="load"
              file="$(find mobile_grasping_ros)/config/arm_position_controller.yaml"/>
    <node name="arm_pos_controller_spawner" pkg="controller_manager"
          type="spawner" output="screen" args="arm_pos_controller"/>
  </group>

  <!-- Velocity controller (deprecated; needs VelocityJointInterface, sags in
       Gazebo). Off by default. -->
  <group if="$(arg spawn_velocity_controller)">
    <rosparam command="load"
              file="$(find mobile_grasping_ros)/config/arm_velocity_controller.yaml"/>
    <node name="arm_vel_controller_spawner" pkg="controller_manager"
          type="spawner" output="screen" args="arm_vel_controller"/>
  </group>

  <!-- Controller -->
  <node pkg="mobile_grasping_ros" type="controller_node.py"
        name="mobile_grasping_controller" output="screen">
    <rosparam command="load"
              file="$(find mobile_grasping_ros)/config/controller_params.yaml"/>
    <param name="control_rate_hz" value="$(arg control_rate_hz)"/>
    <param name="use_base_jacobian" value="$(arg use_base_jacobian)"/>
    <param name="feedback_enabled" value="$(arg feedback_enabled)"/>
    <param name="cmd_interface" value="$(arg cmd_interface)"/>
    <param name="arm_cmd_topic" value="$(arg arm_cmd_topic)"/>
  </node>

  <!-- Eval logger (tracking error -> CSV). Off unless eval:=true. -->
  <group if="$(arg eval)">
    <node pkg="mobile_grasping_ros" type="eval_node.py"
          name="mobile_grasping_eval" output="screen">
      <param name="out_csv" value="$(arg eval_csv)"/>
      <param name="log_rate_hz" value="50.0"/>
    </node>
  </group>

  <!-- Predictor (placeholder fixed pose for bring-up) -->
  <node pkg="mobile_grasping_ros" type="predictor_node.py"
        name="mobile_grasping_predictor" output="screen">
    <param name="publish_rate_hz" value="$(arg predictor_rate_hz)"/>
    <param name="x" value="$(arg target_x)"/>
    <param name="y" value="$(arg target_y)"/>
    <param name="z" value="$(arg target_z)"/>
    <param name="vx" value="$(arg target_vx)"/>
    <param name="vy" value="$(arg target_vy)"/>
    <param name="vz" value="$(arg target_vz)"/>
    <param name="frame_id" value="world"/>
  </node>

  <!-- Estimator -->
  <node pkg="mobile_grasping_ros" type="estimator_node.py"
        name="mobile_grasping_estimator" output="screen">
    <param name="publish_rate_hz" value="$(arg estimator_rate_hz)"/>
  </node>

</launch>
