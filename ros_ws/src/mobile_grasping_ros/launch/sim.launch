<?xml version="1.0"?>
<!--
  sim.launch
  ==========

  Full simulation bring-up: TB3 Waffle Pi + OpenManipulator-X in Gazebo
  Classic, plus our three pipeline nodes (predictor, estimator,
  controller). Uses the official ROBOTIS launch file from the
  turtlebot3_manipulation_gazebo package (noetic branch).

  Assumes the lab PC has been set up per ros_ws/INSTALL.md:
    - turtlebot3 (apt)
    - turtlebot3_manipulation + turtlebot3_manipulation_simulations
      (source, ROBOTIS-GIT, noetic branch)
    - ros-noetic-ros-control*, ros-noetic-control*, ros-noetic-moveit*,
      ros-noetic-dwa-local-planner (apt)
    - TURTLEBOT3_MODEL=waffle_pi (only the Pi variant has the
      OpenCR/OpenManipulator-X integration)
-->
<launch>

  <arg name="model" default="waffle_pi"/>
  <arg name="paused" default="false"/>
  <arg name="use_sim_time" default="true"/>
  <arg name="gui" default="true"/>

  <!-- Pipeline args, forwarded to pipeline.launch below. -->
  <arg name="eval" default="false"/>
  <arg name="eval_csv" default="/tmp/tracking_error.csv"/>
  <arg name="use_base_jacobian" default="false"/>
  <arg name="target_x" default="0.25"/>
  <arg name="target_y" default="0.0"/>
  <arg name="target_z" default="0.20"/>
  <arg name="target_vx" default="0.0"/>
  <arg name="target_vy" default="0.0"/>
  <arg name="target_vz" default="0.0"/>

  <env name="TURTLEBOT3_MODEL" value="$(arg model)"/>

  <!-- Gazebo Classic + TB3+OMX-X bring-up (official ROBOTIS launch) -->
  <include file="$(find turtlebot3_manipulation_gazebo)/launch/turtlebot3_manipulation_gazebo.launch">
    <arg name="paused" value="$(arg paused)"/>
    <arg name="use_sim_time" value="$(arg use_sim_time)"/>
    <arg name="gui" value="$(arg gui)"/>
  </include>

  <!-- Our pipeline nodes (args forwarded so eval/target/M2 toggle work). -->
  <include file="$(find mobile_grasping_ros)/launch/pipeline.launch">
    <arg name="eval" value="$(arg eval)"/>
    <arg name="eval_csv" value="$(arg eval_csv)"/>
    <arg name="use_base_jacobian" value="$(arg use_base_jacobian)"/>
    <arg name="target_x" value="$(arg target_x)"/>
    <arg name="target_y" value="$(arg target_y)"/>
    <arg name="target_z" value="$(arg target_z)"/>
    <arg name="target_vx" value="$(arg target_vx)"/>
    <arg name="target_vy" value="$(arg target_vy)"/>
    <arg name="target_vz" value="$(arg target_vz)"/>
  </include>

</launch>
