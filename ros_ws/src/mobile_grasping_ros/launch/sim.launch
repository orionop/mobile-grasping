<?xml version="1.0"?>
<!--
  sim.launch
  ==========

  Full simulation bring-up: TB3 Waffle + OpenManipulator-X in Gazebo
  Classic, plus our three pipeline nodes (predictor, estimator,
  controller). Assumes the lab PC has the following packages installed
  (see ros_ws/INSTALL.md):

    - turtlebot3 (apt: ros-noetic-turtlebot3-*)
    - turtlebot3_manipulation (from ROBOTIS-GIT/turtlebot3_manipulation,
      noetic-devel branch)
    - turtlebot3_manipulation_simulations (same source)
    - gazebo_ros (apt: ros-noetic-gazebo-ros-pkgs)
-->
<launch>

  <arg name="model" default="waffle"/>
  <arg name="paused" default="false"/>
  <arg name="use_sim_time" default="true"/>
  <arg name="gui" default="true"/>

  <env name="TURTLEBOT3_MODEL" value="$(arg model)"/>

  <!-- Gazebo + TB3 Manipulation world -->
  <include file="$(find turtlebot3_manipulation_gazebo)/launch/empty_world.launch">
    <arg name="paused" value="$(arg paused)"/>
    <arg name="use_sim_time" value="$(arg use_sim_time)"/>
    <arg name="gui" value="$(arg gui)"/>
  </include>

  <!-- Our pipeline nodes -->
  <include file="$(find mobile_grasping_ros)/launch/pipeline.launch"/>

</launch>
